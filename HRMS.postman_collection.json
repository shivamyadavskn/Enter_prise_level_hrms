{
  "info": {
    "name": "HRMS Enterprise API",
    "description": "Complete API collection for HRMS Enterprise backend. Base URL: http://localhost:3001/api\n\nSet the `token` variable after login — all authenticated requests use it automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001/api", "type": "string" },
    { "key": "token",    "value": "",                          "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "var r = pm.response.json();",
            "if (r.data && r.data.accessToken) pm.collectionVariables.set('token', r.data.accessToken);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"superadmin\",\n  \"password\": \"Admin@1234\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth","logout"] },
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth","refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"<your_refresh_token>\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/change-password", "host": ["{{base_url}}"], "path": ["auth","change-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"Admin@1234\",\n  \"newPassword\": \"NewPass@123\"\n}" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth","me"] }
          }
        }
      ]
    },

