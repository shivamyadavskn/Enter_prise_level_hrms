# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@host:port

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# In production both must be >=32 chars and DIFFERENT (validated at boot).
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption (PII at rest) ────────────────────────────────────────────────
# AES-256-GCM key. Must be exactly 32 bytes hex (64 chars).
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset in dev, PII fields are stored as plaintext (a warning is printed).
ENCRYPTION_KEY=

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key from https://resend.com → Settings → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be a verified sender domain in Resend (e.g. hr@yourcompany.com)
EMAIL_FROM=HRMS <hr@yourcompany.com>
# Used in email links and "portal" button URLs
FRONTEND_URL=http://localhost:3000
# Used in email headers and footers
COMPANY_NAME=HRMS Enterprise
