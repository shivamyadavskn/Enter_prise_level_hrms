generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  PLATFORM_ADMIN
  SUPER_ADMIN
  ADMIN
  HR
  MANAGER
  EMPLOYEE
  FINANCE
  INTERN
}

enum EmploymentStatus {
  ACTIVE
  PROBATION
  RESIGNED
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  WFH
  HOLIDAY
}

enum WfhType {
  FULL_DAY
  HALF_DAY
  RECURRING
}

enum PaymentStatus {
  PENDING
  PROCESSED
  PAID
}

enum ReviewType {
  PROBATION
  QUARTERLY
  ANNUAL
  MID_YEAR
}

enum ReviewStatus {
  PENDING
  COMPLETED
  ACKNOWLEDGED
}

enum DocumentType {
  ID_PROOF
  ADDRESS_PROOF
  EDUCATION
  EXPERIENCE
  OFFER_LETTER
  APPOINTMENT_LETTER
  CONFIRMATION_LETTER
  RELIEVING_LETTER
  RESIGNATION_LETTER
  CONTRACT
  PAYSLIP
  OTHER
}

enum HolidayType {
  PUBLIC
  OPTIONAL
  RESTRICTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Organisation {
  id                 Int      @id @default(autoincrement())
  name               String
  slug               String   @unique
  industry           String?
  size               String?
  address            String?
  city               String?
  state              String?
  country            String   @default("India")
  phone              String?
  email              String?
  website            String?
  logoUrl            String?
  financialYearStart Int      @default(4)
  pfEnabled          Boolean  @default(true)
  esicEnabled        Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users           User[]
  employees       Employee[]
  departments     Department[]
  designations    Designation[]
  leaveTypes      LeaveType[]
  holidays        Holiday[]
  onboardingTasks OnboardingTask[]
  customRoles     CustomRole[]

  @@map("organisations")
}

model User {
  id             Int       @id @default(autoincrement())
  organisationId Int?
  username       String    @unique
  email          String    @unique
  passwordHash   String
  role           UserRole  @default(EMPLOYEE)
  isActive       Boolean   @default(true)
  lastLogin      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organisation  Organisation?  @relation(fields: [organisationId], references: [id])
  employee      Employee?
  notifications Notification[]
  uploadedDocs  Document[]     @relation("UploadedBy")
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  payrollRevisions PayrollRevision[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Employee {
  id                    Int              @id @default(autoincrement())
  organisationId        Int?
  userId                Int              @unique
  employeeCode          String
  firstName             String
  lastName              String?
  email                 String?
  phone                 String?
  dateOfBirth           DateTime?
  gender                Gender?
  address               String?
  city                  String?
  state                 String?
  country               String?
  postalCode            String?
  emergencyContactName  String?
  emergencyContactPhone String?
  dateOfJoining         DateTime?
  dateOfConfirmation    DateTime?
  dateOfLeaving         DateTime?
  employmentStatus      EmploymentStatus @default(PROBATION)
  departmentId          Int?
  designationId         Int?
  managerId             Int?
  customRoleId          Int?
  profilePicture        String?
  bankName              String?
  bankAccountNumber     String?
  bankIFSC              String?
  bankAccountHolder     String?
  panNumber             String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  organisation      Organisation? @relation(fields: [organisationId], references: [id])
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  department        Department?   @relation("EmpDept", fields: [departmentId], references: [id])
  designation       Designation?  @relation(fields: [designationId], references: [id])
  manager           Employee?     @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates      Employee[]    @relation("ManagerSubordinates")
  headOfDepartments Department[]  @relation("DeptHead")
  customRole        CustomRole?   @relation(fields: [customRoleId], references: [id])

  leaveBalances           LeaveBalance[]
  leaveApplications       LeaveApplication[]
  leaveWorkflowApprovals  LeaveApprovalWorkflow[]    @relation("WorkflowApprover")
  leaveFinalApprovals     LeaveApplication[]         @relation("LeaveApprover")
  attendanceRecords       Attendance[]
  regularizationRequests  AttendanceRegularization[]
  regularizationApprovals AttendanceRegularization[] @relation("RegApprover")
  wfhRequests             WfhRequest[]
  wfhApprovals            WfhRequest[]               @relation("WfhApprover")
  salaryStructures        SalaryStructure[]
  payrolls                Payroll[]
  reviewsAsEmployee       PerformanceReview[]        @relation("ReviewEmployee")
  reviewsAsReviewer       PerformanceReview[]        @relation("ReviewReviewer")
  documents               Document[]
  reimbursementClaims     ReimbursementClaim[]
  reimbursementApprovals  ReimbursementClaim[]       @relation("ReimbursementApprover")
  experiences             EmployeeExperience[]
  educations              EmployeeEducation[]
  onboardingItems         EmployeeOnboarding[]
  assignedAssets          Asset[]
  announcements           Announcement[]
  travelClaims            TravelClaim[]
  travelApprovals         TravelClaim[]              @relation("TravelApprover")
  pulseResponses          PulseSurveyResponse[]
  payrollRevisions        PayrollRevision[]

  @@unique([organisationId, employeeCode])
  @@map("employees")
}

model OnboardingTask {
  id             Int      @id @default(autoincrement())
  organisationId Int?
  title          String
  description    String?
  category       String   @default("General")
  isRequired     Boolean  @default(true)
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organisation  Organisation?        @relation(fields: [organisationId], references: [id])
  employeeItems EmployeeOnboarding[]

  @@map("onboarding_tasks")
}

model EmployeeOnboarding {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  taskId      Int
  status      String    @default("PENDING")
  completedAt DateTime?
  remarks     String?
  completedBy Int?
  createdAt   DateTime  @default(now())

  employee Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  task     OnboardingTask @relation(fields: [taskId], references: [id])

  @@unique([employeeId, taskId])
  @@map("employee_onboarding")
}

model EmployeeExperience {
  id               Int       @id @default(autoincrement())
  employeeId       Int
  companyName      String
  jobTitle         String
  department       String?
  location         String?
  employmentType   String? // Full-time, Part-time, Contract
  startDate        DateTime
  endDate          DateTime?
  isCurrent        Boolean   @default(false)
  ctc              Float?
  responsibilities String?
  reasonForLeaving String?
  createdAt        DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_experiences")
}

model EmployeeEducation {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  degree       String // B.Tech, MBA, 12th, etc.
  fieldOfStudy String?
  institution  String
  board        String? // University / Board name
  startYear    Int?
  endYear      Int?
  grade        String? // Percentage / CGPA
  createdAt    DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_educations")
}

model Department {
  id             Int      @id @default(autoincrement())
  organisationId Int?
  name           String
  code           String
  headId         Int?
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organisation Organisation? @relation(fields: [organisationId], references: [id])
  head         Employee?     @relation("DeptHead", fields: [headId], references: [id])
  employees    Employee[]    @relation("EmpDept")

  @@unique([organisationId, code])
  @@map("departments")
}

model Designation {
  id             Int      @id @default(autoincrement())
  organisationId Int?
  name           String
  level          Int?
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organisation Organisation? @relation(fields: [organisationId], references: [id])
  employees    Employee[]

  @@map("designations")
}

// ─── Custom Roles (Dynamic, per-organisation) ─────────────────────────────────
// Super Admins create these via the dashboard — no code change needed.
// Each custom role has a base system role it inherits from, plus a JSON
// permissions override map: { "module": ["action1", "action2"] }

model CustomRole {
  id             Int      @id @default(autoincrement())
  organisationId Int
  name           String
  slug           String
  description    String?
  baseRole       UserRole @default(EMPLOYEE)
  permissions    Json     @default("{}")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id])
  employees    Employee[]

  @@unique([organisationId, slug])
  @@map("custom_roles")
}

model LeaveType {
  id                  Int      @id @default(autoincrement())
  organisationId      Int?
  name                String
  code                String
  annualQuota         Int
  carryForwardAllowed Boolean  @default(false)
  maxCarryForward     Int?
  encashmentAllowed   Boolean  @default(false)
  requiresDocument    Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  organisation      Organisation?      @relation(fields: [organisationId], references: [id])
  leaveBalances     LeaveBalance[]
  leaveApplications LeaveApplication[]

  @@unique([organisationId, code])
  @@map("leave_types")
}

model LeaveBalance {
  id             Int      @id @default(autoincrement())
  employeeId     Int
  leaveTypeId    Int
  year           Int
  openingBalance Float    @default(0)
  accrued        Float    @default(0)
  consumed       Float    @default(0)
  available      Float    @default(0)
  updatedAt      DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveApplication {
  id              Int           @id @default(autoincrement())
  employeeId      Int
  leaveTypeId     Int
  startDate       DateTime      @db.Date
  endDate         DateTime      @db.Date
  totalDays       Float
  reason          String?
  documentPath    String?
  status          RequestStatus @default(PENDING)
  appliedOn       DateTime      @default(now())
  approvedById    Int?
  approvedOn      DateTime?
  rejectionReason String?

  employee         Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType        LeaveType               @relation(fields: [leaveTypeId], references: [id])
  approvedBy       Employee?               @relation("LeaveApprover", fields: [approvedById], references: [id])
  approvalWorkflow LeaveApprovalWorkflow[]

  @@map("leave_applications")
}

model LeaveApprovalWorkflow {
  id            Int           @id @default(autoincrement())
  leaveId       Int
  approverId    Int
  approvalLevel Int
  status        RequestStatus @default(PENDING)
  comments      String?
  actionDate    DateTime?

  leave    LeaveApplication @relation(fields: [leaveId], references: [id], onDelete: Cascade)
  approver Employee         @relation("WorkflowApprover", fields: [approverId], references: [id])

  @@map("leave_approval_workflow")
}

model Attendance {
  id                   Int              @id @default(autoincrement())
  employeeId           Int
  date                 DateTime         @db.Date
  clockIn              DateTime?
  clockOut             DateTime?
  totalHours           Float?
  status               AttendanceStatus @default(ABSENT)
  isRegularized        Boolean          @default(false)
  regularizationReason String?
  locationIn           String?
  locationOut          String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  employee        Employee                   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  regularizations AttendanceRegularization[]

  @@unique([employeeId, date])
  @@map("attendance")
}

model AttendanceRegularization {
  id                Int           @id @default(autoincrement())
  attendanceId      Int
  employeeId        Int
  requestedClockIn  DateTime?
  requestedClockOut DateTime?
  reason            String?
  proofDocument     String?
  status            RequestStatus @default(PENDING)
  requestedOn       DateTime      @default(now())
  approvedById      Int?
  approvedOn        DateTime?
  rejectionReason   String?

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id])
  approvedBy Employee?  @relation("RegApprover", fields: [approvedById], references: [id])

  @@map("attendance_regularization")
}

model WfhRequest {
  id              Int           @id @default(autoincrement())
  employeeId      Int
  startDate       DateTime      @db.Date
  endDate         DateTime      @db.Date
  wfhType         WfhType       @default(FULL_DAY)
  reason          String?
  status          RequestStatus @default(PENDING)
  appliedOn       DateTime      @default(now())
  approvedById    Int?
  approvedOn      DateTime?
  rejectionReason String?

  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy Employee? @relation("WfhApprover", fields: [approvedById], references: [id])

  @@map("wfh_requests")
}

model SalaryStructure {
  id                  Int      @id @default(autoincrement())
  employeeId          Int
  effectiveFrom       DateTime @db.Date
  basicSalary         Float    @default(0)
  hra                 Float    @default(0)
  conveyanceAllowance Float    @default(0)
  medicalAllowance    Float    @default(0)
  specialAllowance    Float    @default(0)
  grossSalary         Float    @default(0)
  pfEmployee          Float    @default(0)
  pfEmployer          Float    @default(0)
  professionalTax     Float    @default(0)
  tds                 Float    @default(0)
  totalDeductions     Float    @default(0)
  netSalary           Float    @default(0)
  ctc                 Float    @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("salary_structures")
}

model Payroll {
  id              Int           @id @default(autoincrement())
  employeeId      Int
  month           Int
  year            Int
  workingDays     Int           @default(0)
  presentDays     Float         @default(0)
  paidLeaves      Float         @default(0)
  unpaidLeaves    Float         @default(0)
  wfhDays         Int           @default(0)
  overtimeHours   Float         @default(0)
  grossSalary     Float         @default(0)
  totalDeductions Float         @default(0)
  netSalary       Float         @default(0)
  paymentDate     DateTime?     @db.Date
  paymentStatus   PaymentStatus @default(PENDING)
  payslipPath     String?
  createdAt       DateTime      @default(now())

  employee    Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  adjustments PayrollAdjustment[]

  @@unique([employeeId, month, year])
  @@map("payroll")
}

model PerformanceReview {
  id                 Int          @id @default(autoincrement())
  employeeId         Int
  reviewerId         Int
  reviewPeriodStart  DateTime     @db.Date
  reviewPeriodEnd    DateTime     @db.Date
  reviewType         ReviewType
  selfRating         Float?
  managerRating      Float?
  finalRating        Float?
  strengths          String?
  areasOfImprovement String?
  goalsAchieved      String?
  comments           String?
  status             ReviewStatus @default(PENDING)
  reviewDate         DateTime?    @db.Date
  createdAt          DateTime     @default(now())

  employee Employee @relation("ReviewEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer Employee @relation("ReviewReviewer", fields: [reviewerId], references: [id])

  @@map("performance_reviews")
}

model Document {
  id           Int          @id @default(autoincrement())
  employeeId   Int
  documentType DocumentType @default(OTHER)
  documentName String
  filePath     String
  uploadedById Int
  uploadedOn   DateTime     @default(now())

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@map("documents")
}

model Notification {
  id               Int      @id @default(autoincrement())
  userId           Int
  notificationType String
  title            String
  message          String
  isRead           Boolean  @default(false)
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ReimbursementClaim {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  title           String
  description     String?
  totalAmount     Float
  status          String    @default("PENDING")
  claimDate       DateTime  @default(now())
  approvedById    Int?
  approvedOn      DateTime?
  rejectionReason String?
  items           Json
  receiptPath     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy Employee? @relation("ReimbursementApprover", fields: [approvedById], references: [id])

  @@map("reimbursement_claims")
}

model Holiday {
  id             Int         @id @default(autoincrement())
  organisationId Int?
  name           String
  date           DateTime
  type           HolidayType @default(PUBLIC)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organisation Organisation? @relation(fields: [organisationId], references: [id])

  @@map("holidays")
}

// ─── Permissions ───────────────────────────────────────────────────────────────

model Permission {
  id          Int     @id @default(autoincrement())
  module      String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id             Int      @id @default(autoincrement())
  organisationId Int?
  role           UserRole
  permissionId   Int
  granted        Boolean  @default(true)
  createdAt      DateTime @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([organisationId, role, permissionId])
  @@map("role_permissions")
}

// ─── Announcements ─────────────────────────────────────────────────────────────

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Announcement {
  id             Int                  @id @default(autoincrement())
  organisationId Int?
  title          String
  content        String
  priority       AnnouncementPriority @default(NORMAL)
  isPinned       Boolean              @default(false)
  publishedAt    DateTime             @default(now())
  expiresAt      DateTime?
  createdById    Int
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  createdBy Employee @relation(fields: [createdById], references: [id])

  @@map("announcements")
}

// ─── Asset Tracking ────────────────────────────────────────────────────────────

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
  RETIRED
}

model Asset {
  id             Int            @id @default(autoincrement())
  organisationId Int?
  assetCode      String
  name           String
  category       String
  brand          String?
  modelName      String?
  serialNumber   String?
  purchaseDate   DateTime?
  purchasePrice  Float?
  condition      AssetCondition @default(GOOD)
  assignedToId   Int?
  assignedDate   DateTime?
  notes          String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  assignedTo Employee? @relation(fields: [assignedToId], references: [id])

  @@unique([organisationId, assetCode])
  @@map("assets")
}

// ─── Audit Trail ───────────────────────────────────────────────────────────────

model AuditLog {
  id             Int      @id @default(autoincrement())
  organisationId Int?
  userId         Int
  action         String
  module         String
  entityId       Int?
  entityType     String?
  description    String?
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([organisationId, module, createdAt])
  @@map("audit_logs")
}

// ─── Expense Policies ──────────────────────────────────────────────────────────

model ExpensePolicy {
  id                Int      @id @default(autoincrement())
  organisationId    Int?
  category          String
  maxAmountPerClaim Float?
  maxAmountPerMonth Float?
  requiresReceipt   Boolean  @default(true)
  requiresApproval  Boolean  @default(true)
  autoApproveBelow  Float?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([organisationId, category])
  @@map("expense_policies")
}

// ─── Payroll Adjustments ───────────────────────────────────────────────────────

enum AdjustmentType {
  BONUS
  DEDUCTION
  ADVANCE
  OVERTIME
  INCENTIVE
  REIMBURSEMENT_PAYOUT
}

model PayrollAdjustment {
  id          Int            @id @default(autoincrement())
  payrollId   Int
  type        AdjustmentType
  amount      Float
  description String?
  approvedBy  Int?
  createdAt   DateTime       @default(now())

  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@map("payroll_adjustments")
}

// ─── Payroll Revision History ──────────────────────────────────────────────────

model PayrollRevision {
  id             Int      @id @default(autoincrement())
  employeeId     Int
  changedBy      Int
  changeType     String // SALARY_UPDATE, STRUCTURE_CHANGE, COMPONENT_EDIT
  previousValues Json
  newValues      Json
  reason         String?
  createdAt      DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [changedBy], references: [id], onDelete: Cascade)

  @@index([employeeId, createdAt])
  @@map("payroll_revisions")
}

// ─── Travel Claims ─────────────────────────────────────────────────────────────

enum TravelStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  SETTLED
}

model TravelClaim {
  id              Int          @id @default(autoincrement())
  employeeId      Int
  organisationId  Int?
  title           String
  purpose         String?
  fromCity        String
  toCity          String
  travelStartDate DateTime     @db.Date
  travelEndDate   DateTime     @db.Date
  travelMode      String? // FLIGHT, TRAIN, BUS, CAB, SELF
  hotelAmount     Float        @default(0)
  transportAmount Float        @default(0)
  mealsAmount     Float        @default(0)
  perDiemAmount   Float        @default(0)
  miscAmount      Float        @default(0)
  totalAmount     Float        @default(0)
  itinerary       Json? // Array of day-wise breakdown
  receiptPaths    Json? // Array of file paths
  status          TravelStatus @default(DRAFT)
  approvedById    Int?
  approvedOn      DateTime?
  rejectionReason String?
  remarks         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy Employee? @relation("TravelApprover", fields: [approvedById], references: [id])

  @@index([organisationId, status])
  @@map("travel_claims")
}

// ─── Pulse Survey (Team Mood Check) ────────────────────────────────────────────

enum SurveyFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model PulseSurvey {
  id             Int             @id @default(autoincrement())
  organisationId Int?
  title          String
  question       String          @default("How are you feeling about work this week?")
  frequency      SurveyFrequency @default(WEEKLY)
  isActive       Boolean         @default(true)
  startsAt       DateTime        @default(now())
  endsAt         DateTime?
  createdBy      Int
  createdAt      DateTime        @default(now())

  responses PulseSurveyResponse[]

  @@map("pulse_surveys")
}

model PulseSurveyResponse {
  id         Int      @id @default(autoincrement())
  surveyId   Int
  employeeId Int
  rating     Int // 1-5
  comment    String?
  weekLabel  String // e.g. "2026-W16" for dedup
  createdAt  DateTime @default(now())

  survey   PulseSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([surveyId, employeeId, weekLabel])
  @@map("pulse_survey_responses")
}
